#pragma once

#define RETARGETING_VERSION "@PROJECT_VERSION@"
#define RETARGETING_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define RETARGETING_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define RETARGETING_VERSION_PATCH @PROJECT_VERSION_PATCH@

namespace retargeting {

inline constexpr const char* kVersion = RETARGETING_VERSION;
inline constexpr int kVersionMajor = RETARGETING_VERSION_MAJOR;
inline constexpr int kVersionMinor = RETARGETING_VERSION_MINOR;
inline constexpr int kVersionPatch = RETARGETING_VERSION_PATCH;

inline constexpr const char* version() {
  return kVersion;
}

}  // namespace retargeting
